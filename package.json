{
  "name": "sandpiper-middle-school",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:staging": "dotenv -e .env.staging -e .env.staging.local -- next build",
    "build:production": "dotenv -e .env.production -e .env.production.local -- next build",
    "deploy:staging": "dotenv -e .env.staging -e .env.staging.local -- next build && firebase deploy -P staging",
    "deploy:production": "dotenv -e .env.production -e .env.production.local -- next build && firebase deploy -P production"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "lucide-react": "^0.574.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.24",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2"
  }
}
